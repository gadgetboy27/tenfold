# ============================================================
# tenfold.nz — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is in .gitignore
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
# Settings → API → Project URL + anon/public key + service_role key
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_XXXXXXXXXXXXXXXXXXXXXXXX
SUPABASE_SERVICE_ROLE_KEY=sb_secret_XXXXXXXXXXXXXXXXXXXXXXXX

# ── Database (Drizzle ORM) ─────────────────────────────────────
# Settings → Database → Connection string (Transaction pooler, port 6543)
# Format: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.your-project-ref:your-db-password@aws-0-ap-southeast-2.pooler.supabase.com:6543/postgres

# ── App URL ────────────────────────────────────────────────────
# No trailing slash. Use http://localhost:3000 for dev, https://tenfold.nz in prod.
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── fal.ai ────────────────────────────────────────────────────
# Get from: https://fal.ai/dashboard/keys
FAL_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Anthropic ─────────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Meta (Facebook + Instagram) OAuth ────────────────────────
# Create app at: https://developers.facebook.com/apps/
# App Dashboard → Settings → Basic → App ID + App Secret
# Required permissions: pages_show_list, pages_manage_posts, pages_read_engagement,
#                       instagram_basic, instagram_content_publish
# Redirect URI to register: {APP_URL}/api/social/callback/facebook
META_APP_ID=XXXXXXXXXXXXXXXX
META_APP_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Direct social connections (lib/social/providers.ts) ───────
# Signs the OAuth `state` param — our own CSRF token, not any provider's, so
# it just needs to be a long random server-side secret (openssl rand -hex 32).
# Falls back to META_APP_SECRET when unset, so existing deploys keep working.
OAUTH_STATE_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Reddit — self-serve, no app review. Create a "web app" at:
# https://www.reddit.com/prefs/apps  → scopes: identity, submit
# Redirect URI to register: {APP_URL}/api/social/callback/reddit
REDDIT_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXX
REDDIT_CLIENT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# LinkedIn and TikTok go here once approved — both are gated on review, not code:
#   LinkedIn: Community Management API is a vetted product (Development Tier →
#             Standard Tier needs a screencast + technical sign-off).
#   TikTok:   Content Posting API audits your app before it will publish
#             publicly; unaudited clients are limited to private-only posts, and
#             PULL_FROM_URL needs a domain YOU own verified (Supabase Storage
#             URLs won't qualify — serve the media from tenfold.nz or upload it).

# ── Ayrshare ──────────────────────────────────────────────────
# Business Plan account. Get the API key from: https://app.ayrshare.com/dashboard/api
AYRSHARE_API_KEY=XXXXXXXX-XXXXXXXX-XXXXXXXX-XXXXXXXX
# Hosted social-connect (generateJWT) for the non-Meta networks. One-time setup:
# Ayrshare dashboard (Business) → User Profiles → generate the JWT key pair + domain.
# Store the PEM with literal \n between lines (the code restores real newlines).
AYRSHARE_DOMAIN=
AYRSHARE_PRIVATE_KEY=

# ── Stripe ────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=your_stripe_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
# Get from: https://dashboard.stripe.com/webhooks (add endpoint → select all events)
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Stripe Price IDs — Dashboard → Products → create one price per plan (recurring, monthly, NZD)
STRIPE_PRICE_25CR=price_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_100CR=price_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_300CR=price_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_CREATOR_MONTHLY=price_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_BUSINESS_MONTHLY=price_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_AGENCY_MONTHLY=price_XXXXXXXXXXXXXXXXXXXXXXXX

# ── Resend ────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Auth: set to "false" to require email confirmation before login (default: auto-confirm on)
AUTH_AUTOCONFIRM_SIGNUP=true

# ── Admin override (live testing) ──────────────────────────────
# Comma-separated emails that unlock the FULL toolset (top tier) regardless of
# subscription. Matched against the WORKSPACE OWNER's email. Leave empty in
# normal operation. e.g. ADMIN_EMAILS=you@example.com,teammate@example.com
ADMIN_EMAILS=
