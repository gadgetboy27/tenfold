{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "startCommand": "npm run start",
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 5
  },
  "plugins": [
    "postgres"
  ],
  "variables": {
    "NEXT_PUBLIC_SUPABASE_URL": {
      "description": "Supabase project URL",
      "value": ""
    },
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": {
      "description": "Supabase public anon key",
      "value": ""
    },
    "SUPABASE_SERVICE_ROLE_KEY": {
      "description": "Supabase service role key (server-side only)",
      "value": ""
    },
    "FAL_API_KEY": {
      "description": "fal.ai API key for image/video generation",
      "value": ""
    },
    "ANTHROPIC_API_KEY": {
      "description": "Anthropic API key for Claude",
      "value": ""
    },
    "AYRSHARE_API_KEY": {
      "description": "Ayrshare API key for social publishing",
      "value": ""
    },
    "STRIPE_SECRET_KEY": {
      "description": "Stripe secret key (server-side only)",
      "value": ""
    },
    "STRIPE_WEBHOOK_SECRET": {
      "description": "Stripe webhook signing secret",
      "value": ""
    },
    "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY": {
      "description": "Stripe publishable key (client-side)",
      "value": ""
    },
    "STRIPE_PRICE_25CR": {
      "description": "Stripe price ID for 25-credit pack",
      "value": ""
    },
    "STRIPE_PRICE_100CR": {
      "description": "Stripe price ID for 100-credit pack",
      "value": ""
    },
    "STRIPE_PRICE_300CR": {
      "description": "Stripe price ID for 300-credit pack",
      "value": ""
    },
    "STRIPE_PRICE_CREATOR_MONTHLY": {
      "description": "Stripe price ID for Creator plan",
      "value": ""
    },
    "STRIPE_PRICE_BUSINESS_MONTHLY": {
      "description": "Stripe price ID for Business plan",
      "value": ""
    },
    "STRIPE_PRICE_AGENCY_MONTHLY": {
      "description": "Stripe price ID for Agency plan",
      "value": ""
    },
    "RESEND_API_KEY": {
      "description": "Resend email API key",
      "value": ""
    },
    "CRON_SECRET": {
      "description": "Secret for internal cron/background job endpoints",
      "value": ""
    },
    "NODE_ENV": {
      "description": "Node environment",
      "value": "production"
    }
  }
}
